{
  "dashboard": {
    "id": null,
    "uid": null,
    "title": "MetroSaathi Overview",
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 0,
    "panels": [
      {
        "type": "stat",
        "title": "Engineers Active",
        "datasource": { "type": "prometheus", "uid": "bbf3597c-cac7-4054-9c41-df125ff7b2d3" },
        "targets": [{ "expr": "metrosaathi_engineers_active" }],
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "type": "table",
        "title": "Engineer Assigned Jobs",
        "datasource": { "type": "prometheus", "uid": "YOUR_PROM_DS_UID" },
        "targets": [{ "expr": "metrosaathi_engineer_jobs" }],
        "gridPos": { "x": 6, "y": 0, "w": 12, "h": 6 }
      },
      {
        "type": "stat",
        "title": "DL Model Trained",
        "datasource": { "type": "prometheus", "uid": "YOUR_PROM_DS_UID" },
        "targets": [{ "expr": "metrosaathi_dl_model_trained" }],
        "gridPos": { "x": 0, "y": 4, "w": 4, "h": 4 },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "No", "color": "red" }, "1": { "text": "Yes", "color": "green" } } }
            ]
          }
        }
      },
      {
        "type": "gauge",
        "title": "DL Model Val Accuracy",
        "datasource": { "type": "prometheus", "uid": "YOUR_PROM_DS_UID" },
        "targets": [{ "expr": "metrosaathi_dl_model_val_accuracy" }],
        "gridPos": { "x": 4, "y": 4, "w": 8, "h": 4 },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "green", "value": 0.85 }
              ]
            }
          }
        }
      },
      {
        "type": "stat",
        "title": "Rakes UNFIT",
        "datasource": { "type": "prometheus", "uid": "YOUR_PROM_DS_UID" },
        "targets": [{ "expr": "metrosaathi_rakes_unfit" }],
        "gridPos": { "x": 0, "y": 8, "w": 4, "h": 4 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "type": "stat",
        "title": "Rakes Total",
        "datasource": { "type": "prometheus", "uid": "YOUR_PROM_DS_UID" },
        "targets": [{ "expr": "metrosaathi_rakes_total" }],
        "gridPos": { "x": 4, "y": 8, "w": 4, "h": 4 }
      },
      {
        "type": "gauge",
        "title": "Rakes UNFIT %",
        "datasource": { "type": "prometheus", "uid": "YOUR_PROM_DS_UID" },
        "targets": [
          { "expr": "(metrosaathi_rakes_unfit / metrosaathi_rakes_total) * 100" }
        ],
        "gridPos": { "x": 8, "y": 8, "w": 8, "h": 4 },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 25 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        }
      },
      {
        "type": "timeseries",
        "title": "Rakes UNFIT Over Time",
        "datasource": { "type": "prometheus", "uid": "YOUR_PROM_DS_UID" },
        "targets": [{ "expr": "metrosaathi_rakes_unfit" }],
        "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 }
      }
    ]
  },
  "overwrite": true
}
